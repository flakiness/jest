{
  "name": "@flakiness/jest",
  "version": "0.0.1",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flakiness/jest.git"
  },
  "exports": {
    ".": {
      "types": "./types/src/reporter.d.ts",
      "import": "./lib/reporter.js",
      "require": "./lib/reporter.js"
    }
  },
  "type": "module",
  "description": "A custom Jest reporter that generates Flakiness Reports from your test runs",
  "types": "./types/index.d.ts",
  "scripts": {
    "build": "kubik build.mts",
    "watch": "kubik build.mts -w",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "jest",
    "test",
    "reporter",
    "flakiness",
    "testing",
    "e2e",
    "test-reporting"
  ],
  "author": "Degu Labs, Inc",
  "license": "MIT",
  "devDependencies": {
    "@jest/reporters": "^30.3.0",
    "@swc/core": "^1.15.30",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "esbuild": "^0.27.2",
    "jest": "^30.3.0",
    "kubik": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@flakiness/flakiness-report": "^0.33.0",
    "@flakiness/sdk": "^3.0.0"
  }
}
